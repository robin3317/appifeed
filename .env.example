# Copy to .env and fill in real values. Do NOT commit .env.

# Neon Postgres connection string (https://neon.tech). Needs sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js session-signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Vercel Blob token for image uploads (Vercel dashboard -> Storage -> Blob).
BLOB_READ_WRITE_TOKEN=""
